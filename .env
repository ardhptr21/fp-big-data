# =============================================
# Environment Variables - Big Data Lakehouse
# =============================================

# HDFS
HDFS_NAMENODE_HOST=namenode
HDFS_PORT=9000
HDFS_URL=hdfs://namenode:9000

# Kafka
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_TOPIC_SURVEY=survey-events
KAFKA_TOPIC_SECONDARY=secondary-batch

# Spark
SPARK_MASTER=spark://spark:7077

# API
API_URL=http://api:8000
API_PORT=8000

# Frontend
FRONTEND_PORT=3000

# Zookeeper
ZOOKEEPER_HOST=zookeeper
ZOOKEEPER_PORT=2181
